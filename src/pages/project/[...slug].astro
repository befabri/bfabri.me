---
import ProjectDescription from "@components/ProjectDescription.astro";
import { getLangFromUrl } from "@i18n/utils";
import { defaultLang } from "@i18n/ui";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAdjacentProjects, getProjects } from "@utils/fetchers";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const projectEntries = await getCollection("project");
    return projectEntries
        .filter((entry) => !entry.data.draft && !entry.id.startsWith(`${defaultLang}/`) && !entry.id.includes("/"))
        .map((entry) => ({
            params: { slug: entry.id },
            props: { entry },
        }));
}

const { entry } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const projects = await getProjects(lang);
const { nextProject } = getAdjacentProjects(projects, entry.id);
---

<BaseLayout title={entry.data.name} chrome="none">
    <ProjectDescription
        project={entry}
        nextProject={nextProject}
    />
</BaseLayout>
