---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ProjectDescription from "@components/ProjectDescription.astro";
import { getLangFromUrl } from "@i18n/utils";
import { getAdjacentProjects, getProjects } from "@utils/fetchers";

export async function getStaticPaths() {
    const pages = await getCollection("project");
    return pages
        .filter((page) => !page.data.draft && page.id.startsWith("en/"))
        .map((page) => ({
            params: { slug: page.id.replace(/^en\//, "") },
            props: { page },
        }));
}

const { page } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const projects = await getProjects(lang);
const { nextProject } = getAdjacentProjects(projects, page.id);
---

<BaseLayout title={page.data.name} chrome="none">
    <ProjectDescription
        project={page}
        nextProject={nextProject}
    />
</BaseLayout>
