---
import Footer from "@components/layouts/Footer.astro";
import Head from "@components/layouts/Head.astro";
import Header from "@components/layouts/Header.astro";
import Container from "./common/Container.astro";
import { getLangFromUrl } from "@i18n/utils";

interface Props {
    title: string;
    chrome?: "default" | "none";
}

const { title, chrome = "default" } = Astro.props;
const hasChrome = chrome !== "none";

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
    <Head title={title} />
    <body
        class:list={[
            "antialiased",
            hasChrome
                ? "bg-portfolio-bg text-portfolio-ink"
                : "bg-portfolio-bg text-portfolio-ink",
        ]}>
        {
            hasChrome ? (
                <>
                    <Header />
                    <Container>
                        <slot />
                    </Container>
                    <Footer />
                </>
            ) : (
                <slot />
            )
        }
        <style is:global>
            /* Improve Page speed */
            /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
            img {
                content-visibility: auto;
            }
        </style>
    </body>
</html>
