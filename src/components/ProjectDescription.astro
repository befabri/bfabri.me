---
import { ArrowRight, ArrowUpRight } from "@lucide/astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import ImageFullScreen from "@components/ui/ImageFullScreen";
import ToggleTheme from "@components/ui/ToggleTheme.astro";
import { defaultLang } from "@i18n/ui";
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";
import { getImageTone } from "@utils/imageTone";
import type { Project } from "../content.config";

const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/project/*.{jpeg,jpg,png,gif,webp}");
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/project/*/*.{jpeg,jpg,png,gif,webp}"
);

interface Props {
    project: Project;
    nextProject: Project;
}

const { project, nextProject } = Astro.props;
const { Content } = await render(project);

const lang = getLangFromUrl(Astro.url);
const isFr = lang === defaultLang;
const translatePath = useTranslatedPath(lang);
const email = "contact@bfabri.me";
const homepagePath = translatePath("/");
const nextHref = translatePath(`/project/${nextProject.id}/`);
const pathname = new URL(Astro.request.url).pathname;
const languageHref = isFr ? `/en${pathname}` : pathname.replace(/^\/en\/?/, "/");
const stack = project.data.tag.map((t) => t.name).join(" · ");
const galleryItems = project.data.images.slice(0, 4);
const galleryCount = galleryItems.length;
const cover = project.data.image;
const coverTone = cover ? await getImageTone(cover.src) : "dark";
const galleryTones = await Promise.all(galleryItems.map((img) => getImageTone(img.src)));
const captionToneClass = (tone: "light" | "dark") =>
    tone === "dark" ? "text-white/85" : "text-portfolio-ink/70";
const galleryGridClass =
    galleryCount <= 1
        ? "min-[821px]:grid-cols-1"
        : galleryCount === 2
          ? "min-[821px]:grid-cols-2"
          : galleryCount === 3
            ? "min-[821px]:grid-cols-3"
            : "min-[821px]:grid-cols-4";
const year = new Date().getFullYear();
const projectMeta = project.id === "trpcgo"
    ? isFr
        ? "Open-source · mainteneur unique"
        : "Open-source · sole maintainer"
    : isFr
      ? "Projet perso · solo"
      : "Side project · solo";

const copy = {
    back: isFr ? "Index" : "Index",
    meta: projectMeta,
    year: isFr ? "Année" : "Year",
    role: isFr ? "Rôle" : "Role",
    stack: isFr ? "Stack" : "Stack",
    links: isFr ? "Liens" : "Links",
    live: isFr ? "En ligne" : "Live",
    code: isFr ? "Code" : "Code",
    website: isFr ? "Site web" : "Website",
    source: isFr ? "Code source" : "Source code",
    caseStudy: isFr ? "Case study" : "Case study",
    pitch: isFr ? "Le pitch" : "The pitch",
    details: isFr ? "Détails" : "Details",
    keyFeatures: isFr ? "Fonctionnalités clés" : "Key features",
    moreLinks: isFr ? "Autres liens" : "More links",
    language: isFr ? "EN" : "FR",
    toolbelt: isFr ? "Technologies" : "Toolbelt",
    nextProject: isFr ? "Projet suivant" : "Next project",
    gallery: isFr ? "Captures" : "Screenshots",
};

const projectType = project.data.links.website ? copy.live : project.data.links.project ? copy.code : copy.caseStudy;
const fallbackLinkItems: Array<{ label: string; href: string }> = [];

if (project.data.links.website) {
    fallbackLinkItems.push({ label: copy.website, href: project.data.links.website });
}

if (project.data.links.project) {
    fallbackLinkItems.push({ label: copy.source, href: project.data.links.project });
}

const linkItems = project.data.links.items?.length ? project.data.links.items : fallbackLinkItems;
const primaryLink = fallbackLinkItems[0] || linkItems[0];
const additionalLinkItems = primaryLink
    ? linkItems.filter((link) => link.href !== primaryLink.href)
    : [];

const hasDetails = project.body !== undefined && project.body.trim().length > 0;
const keyFeatures = project.data.keyFeatures ?? [];
const hasKeyFeatures = keyFeatures.length > 0;
const featuresCharCount = keyFeatures.join(" ").length;
const detailsCharCount = project.body?.trim().length ?? 0;
const compactBody = hasKeyFeatures && hasDetails && featuresCharCount + detailsCharCount < 1500;
const pitchText = project.data.tldr ?? project.data.description;

const tagCount = project.data.tag.length;
const tagGridClass =
    tagCount <= 1
        ? "min-[821px]:grid-cols-1"
        : tagCount === 2
          ? "min-[821px]:grid-cols-2"
          : tagCount === 3
            ? "min-[821px]:grid-cols-3"
            : tagCount === 4
              ? "min-[821px]:grid-cols-4"
              : tagCount === 5
                ? "min-[821px]:grid-cols-5"
                : tagCount === 6
                  ? "min-[821px]:grid-cols-3"
                  : "min-[821px]:grid-cols-4";

const featuresListClasses =
    "flex flex-col [counter-reset:item]";
const featureItemClasses =
    "flex gap-3.5 border-t border-portfolio-ink py-4 text-[16px] leading-[1.45] first:border-t-0 first:pt-0 before:min-w-[26px] before:text-xs before:text-portfolio-blue before:tabular-nums before:[counter-increment:item] before:content-[counter(item,decimal-leading-zero)]";
const proseClasses =
    "prose max-w-[64ch] text-portfolio-ink prose-headings:tracking-[-0.025em] prose-headings:text-portfolio-ink prose-p:text-[17px] prose-p:leading-[1.55] prose-a:text-portfolio-ink prose-a:no-underline prose-a:hover:text-portfolio-blue prose-strong:text-portfolio-ink prose-li:text-[16px] prose-li:leading-[1.45]";
const cardClasses =
    "rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-10 py-9 max-[820px]:px-6 max-[820px]:py-7";
const sectionLabelClasses =
    "mb-[18px] text-[13px] font-medium tracking-[-0.005em] text-portfolio-muted";
---

<div class="mx-auto flex max-w-screen-xl flex-col gap-2.5 px-3.5 pb-[60px] pt-3.5 font-portfolio text-portfolio-ink antialiased [font-feature-settings:'ss01','cv11'] max-[560px]:px-2.5">
    <header class="flex items-baseline justify-between gap-4 px-1 text-sm tracking-[-0.01em] max-[560px]:items-start">
        <a class="inline-flex items-center gap-1.5 text-portfolio-muted transition-colors hover:text-portfolio-ink" href={homepagePath}>
            ← {copy.back}
        </a>
        <div class="inline-flex items-center gap-2 whitespace-nowrap font-semibold">
            {project.data.name}<span class="text-portfolio-blue">.</span>
        </div>
        <nav class="flex items-baseline gap-[22px] whitespace-nowrap max-[560px]:gap-3.5 max-[560px]:text-[13px]" aria-label="Project navigation">
            <a class="text-portfolio-muted transition-colors hover:text-portfolio-ink" href={languageHref}>{copy.language}</a>
            <a class="text-portfolio-muted transition-colors hover:text-portfolio-ink max-[560px]:hidden" href="https://github.com/befabri/" target="_blank" rel="noopener">GitHub</a>
            <ToggleTheme />
            <a class="border-b-[1.5px] border-portfolio-blue pb-px text-portfolio-ink" href={`mailto:${email}`}>{email}</a>
        </nav>
    </header>

    <main class="flex flex-col gap-2.5">
        <section class="flex flex-col gap-7 rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-14 py-12 max-[820px]:px-6 max-[820px]:py-9">
            <div class="flex items-baseline justify-between gap-4 text-sm text-portfolio-muted max-[560px]:flex-col">
                <span class="inline-flex items-center gap-2 before:inline-block before:size-[7px] before:rounded-full before:bg-portfolio-blue before:content-['']">
                    {copy.meta}
                </span>
                <span class="tabular-nums">{project.data.year}</span>
            </div>
            <h1 class="text-balance text-[clamp(56px,9vw,144px)] font-semibold leading-[0.88] tracking-[-0.05em]">
                {project.data.name}<span class="text-portfolio-blue">.</span>
            </h1>
            <p class="max-w-[64ch] text-pretty text-[clamp(18px,1.6vw,24px)] leading-[1.35]">
                {project.data.description}
            </p>
        </section>

        <section class="grid gap-2.5 min-[821px]:grid-cols-4">
            <div class="rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-6 py-[22px]">
                <div class="text-xs text-portfolio-muted">{copy.year}</div>
                <div class="mt-2 text-[17px] font-medium leading-[1.3] tracking-[-0.01em] tabular-nums">{project.data.year}</div>
            </div>
            <div class="rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-6 py-[22px]">
                <div class="text-xs text-portfolio-muted">{copy.role}</div>
                <div class="mt-2 text-[17px] font-medium leading-[1.3] tracking-[-0.01em]">{copy.meta}</div>
            </div>
            <div class="rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-6 py-[22px]">
                <div class="text-xs text-portfolio-muted">{copy.links}</div>
                <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-[17px] font-medium leading-[1.3] tracking-[-0.01em]">
                    <span class="text-portfolio-blue">●</span>
                    {
                        primaryLink ? (
                            <a class="border-b border-portfolio-blue pb-px hover:text-portfolio-blue" href={primaryLink.href} target="_blank" rel="noopener">
                                {primaryLink.label}
                            </a>
                        ) : (
                            <span>{copy.caseStudy}</span>
                        )
                    }
                </div>
            </div>
            <div class="rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-6 py-[22px]">
                <div class="text-xs text-portfolio-muted">{copy.stack}</div>
                <div class="mt-2 text-[17px] font-medium leading-[1.3] tracking-[-0.01em]">{stack}</div>
            </div>
        </section>

        <section class="grid gap-2.5 min-[821px]:grid-cols-[2fr_1fr]">
            {cover ? (
                <figure class="relative m-0 aspect-video overflow-hidden rounded-portfolio border border-portfolio-ink bg-portfolio-soft">
                    <Image
                        src={images[cover.src]()}
                        alt={cover.alt}
                        format="webp"
                        loading="eager"
                        decoding="async"
                        width={1700}
                        class="h-full w-full object-cover object-top"
                        transition:name={`img-${project.id}`}
                    />
                    <span class:list={["absolute right-6 top-[18px] text-xs font-medium tabular-nums", captionToneClass(coverTone)]}>Fig. 01</span>
                    <span class:list={["absolute bottom-[18px] left-6 max-w-[80%] text-[13px] font-medium", captionToneClass(coverTone)]}>{cover.alt}</span>
                </figure>
            ) : (
                <div class="relative flex aspect-video items-center justify-center overflow-hidden rounded-portfolio border border-portfolio-ink bg-portfolio-blue px-10 py-10 text-white">
                    <span class="text-balance text-center text-[clamp(48px,7vw,112px)] font-semibold leading-[0.9] tracking-[-0.045em]">
                        {project.data.name}<span class="opacity-60">.</span>
                    </span>
                    <span class="absolute right-6 top-[18px] text-xs font-medium tabular-nums text-white/70">Fig. 01</span>
                </div>
            )}
            <aside class="flex flex-col rounded-portfolio border border-portfolio-ink bg-portfolio-ink px-10 py-9 text-portfolio-bg max-[820px]:px-6 max-[820px]:py-7">
                <h2 class="text-[13px] font-medium tracking-[-0.005em] text-portfolio-bg/60">{copy.pitch}</h2>
                <p class="mt-7 text-balance text-[clamp(20px,2vw,32px)] font-medium leading-[1.15] tracking-[-0.025em]">
                    {pitchText}
                </p>
                <div class="mt-auto inline-flex items-center gap-2 pt-8 text-[13px] text-portfolio-bg/60 before:inline-block before:size-[7px] before:rounded-full before:bg-portfolio-blue before:content-['']">
                    {projectType} · <span class="tabular-nums">{project.data.year}</span>
                </div>
            </aside>
        </section>

        {
            additionalLinkItems.length > 0 && (
                <section class="rounded-portfolio border border-portfolio-ink bg-portfolio-bg px-10 py-9 max-[820px]:px-6 max-[820px]:py-7">
                    <h2 class="mb-[18px] text-[13px] font-medium text-portfolio-muted">{copy.moreLinks}</h2>
                    <div class="grid gap-2.5 min-[821px]:grid-cols-4 max-[820px]:grid-cols-2 max-[560px]:grid-cols-1">
                        {additionalLinkItems.map((link, index) => (
                            <a class="group flex flex-col border-t border-portfolio-ink pt-3.5" href={link.href} target="_blank" rel="noopener">
                                <div class="text-xs text-portfolio-muted tabular-nums">Link {String(index + 1).padStart(2, "0")}</div>
                                <div class="mt-1 inline-flex items-center gap-1.5 text-lg font-medium tracking-[-0.02em] group-hover:text-portfolio-blue">
                                    <span class="truncate">{link.label}</span>
                                    <ArrowUpRight class="size-4 shrink-0 text-portfolio-muted transition-[color,transform] group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-portfolio-blue" />
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            )
        }

        {
            galleryCount > 0 && (
                <section class:list={["grid gap-2.5", galleryGridClass]} aria-label={copy.gallery}>
                    {galleryItems.map((image, index) => (
                        <figure class="relative m-0 aspect-video overflow-hidden rounded-portfolio border border-portfolio-ink bg-portfolio-soft">
                            <ImageFullScreen client:load>
                                <Image
                                    src={projectImages[image.src]()}
                                    alt={image.alt}
                                    format="webp"
                                    loading="lazy"
                                    width={1200}
                                    class="h-full w-full object-contain"
                                />
                            </ImageFullScreen>
                            <figcaption class:list={["absolute bottom-3.5 left-[18px] right-[18px] text-xs font-medium", captionToneClass(galleryTones[index])]}>Fig. {String(index + 2).padStart(2, "0")} — {image.alt}</figcaption>
                        </figure>
                    ))}
                </section>
            )
        }

        {
            compactBody ? (
                <section class="grid gap-2.5 min-[821px]:grid-cols-2">
                    <article class={cardClasses}>
                        <h2 class={sectionLabelClasses}>{copy.keyFeatures}</h2>
                        <ul class={featuresListClasses}>
                            {keyFeatures.map((feature) => (
                                <li class={featureItemClasses}>
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                    </article>
                    <article class={cardClasses}>
                        <h2 class={sectionLabelClasses}>{copy.details}</h2>
                        <div class={proseClasses}>
                            <Content />
                        </div>
                    </article>
                </section>
            ) : (
                <>
                    {hasKeyFeatures && (
                        <section class={cardClasses}>
                            <h2 class={sectionLabelClasses}>{copy.keyFeatures}</h2>
                            <ul class:list={[featuresListClasses, "max-w-[72ch]"]}>
                                {keyFeatures.map((feature) => (
                                    <li class={featureItemClasses}>
                                        <span>{feature}</span>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )}
                    {hasDetails && (
                        <section class={cardClasses}>
                            <h2 class={sectionLabelClasses}>{copy.details}</h2>
                            <div class={proseClasses}>
                                <Content />
                            </div>
                        </section>
                    )}
                </>
            )
        }

        <section class={cardClasses}>
            <h2 class={sectionLabelClasses}>{copy.toolbelt}</h2>
            <div class:list={["grid gap-2.5 max-[820px]:grid-cols-2", tagGridClass]}>
                {
                    project.data.tag.map((tag) => (
                        <div class="border-t border-portfolio-ink pt-3.5">
                            <div class="text-lg font-medium tracking-[-0.02em]">{tag.name}</div>
                            {tag.note && (
                                <div class="mt-1 text-[13px] leading-[1.35] text-portfolio-muted">{tag.note}</div>
                            )}
                        </div>
                    ))
                }
            </div>
        </section>

        <a class="flex items-center justify-between gap-6 rounded-portfolio border border-portfolio-ink bg-portfolio-ink px-12 py-10 text-portfolio-bg transition-colors hover:bg-portfolio-blue max-[560px]:items-start max-[560px]:px-6 max-[560px]:py-7" href={nextHref}>
            <div>
                <div class="text-[13px] text-portfolio-bg/65">{copy.nextProject}</div>
                <div class="mt-2 text-[clamp(32px,5vw,56px)] font-semibold leading-none tracking-[-0.04em]">
                    {nextProject.data.name}
                </div>
            </div>
            <ArrowRight class="size-14 -rotate-45" />
        </a>
    </main>

    <footer class="flex justify-between gap-4 rounded-portfolio border border-portfolio-ink px-[18px] py-3.5 text-[13px] text-portfolio-muted max-[560px]:flex-col">
        <span>Benjamin Fabri · Brussels</span>
        <a class="hover:text-portfolio-ink" href={homepagePath}>Index</a>
        <span>© {year}</span>
    </footer>
</div>
