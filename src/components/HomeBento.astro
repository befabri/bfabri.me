---
import { ArrowRight, ArrowUpRight } from "@lucide/astro";
import ToggleTheme from "@components/ui/ToggleTheme.astro";
import { defaultLang } from "@i18n/ui";
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";
import { getProjects } from "@utils/fetchers";

const lang = getLangFromUrl(Astro.url);
const isFr = lang === defaultLang;
const translatePath = useTranslatedPath(lang);
const projects = await getProjects(lang);
const featured = projects[0];
const projectCards = projects.slice(1, 4);
const email = "contact@bfabri.me";
const pathname = new URL(Astro.request.url).pathname;
const languageHref = isFr ? `/en${pathname}` : pathname.replace(/^\/en\/?/, "/");
const stackSummary = ["Go", "TypeScript", "React", "Next.js", "Astro", "Cloudflare", "React Native"].join(" · ");

const copy = {
    roleLead: isFr ? "Développeur full-stack." : "Full-stack developer.",
    role: isFr
        ? "Je construis des apps web : type safety du back au front, services edge et interfaces sobres qui restent efficaces."
        : "I build web apps: end-to-end type safety, edge services, and quiet interfaces that stay useful.",
    locationCity: isFr ? "Bruxelles" : "Brussels",
    workLabel: isFr ? "travaille chez" : "working at",
    meta: isFr ? "Depuis 2017" : "Since 2017",
    selected: isFr ? "Projets sélectionnés" : "Selected work",
    featured: isFr ? "À la une" : "Featured",
    openCase: isFr ? "Voir le projet" : "Open case",
    count: stackSummary,
    language: isFr ? "EN" : "FR",
    contact: isFr ? "Contact" : "Contact",
    contactStatus: isFr ? "Ouvert à discuter" : "Open to chat",
};

const cardClass =
    "relative flex min-h-0 min-w-0 flex-col overflow-hidden rounded-portfolio border border-portfolio-ink bg-portfolio-bg";
const linkCardClass =
    "group justify-between px-6 py-[22px] transition-[transform,color,box-shadow] duration-500 ease-out will-change-transform hover:z-[2] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:text-portfolio-bg hover:shadow-[4px_4px_0_0_var(--color-portfolio-ink)] before:pointer-events-none before:absolute before:inset-0 before:bg-portfolio-ink before:opacity-0 before:[clip-path:circle(0%_at_var(--reveal-x)_var(--reveal-y))] before:[transition:opacity_250ms_ease-out,clip-path_0ms_250ms] hover:before:opacity-100 hover:before:[clip-path:circle(150%_at_var(--reveal-x)_var(--reveal-y))] hover:before:[transition:opacity_0ms,clip-path_800ms_ease-out] [&>*]:relative max-[560px]:p-5";
const revealRight = "[--reveal-x:100%] [--reveal-y:0%]";
const revealLeft = "[--reveal-x:0%] [--reveal-y:100%]";
const projectCardCorners = [revealLeft, revealRight, revealLeft];
const projectCardSides = ["left", "right", "left"] as const;
const projectCardLayouts = [
    "min-[901px]:col-span-3 min-[901px]:row-span-2",
    "min-[901px]:col-span-3 min-[901px]:row-span-2",
    "min-[901px]:col-span-3 min-[901px]:row-span-1 min-[901px]:[&_.sub]:hidden min-[901px]:[&_.stack]:hidden min-[901px]:[&_.top]:text-[11px] min-[901px]:[&_h3]:text-[clamp(20px,1.6vw,26px)] min-[901px]:[&_h3]:line-clamp-2",
];
const contactLayout = "min-[901px]:col-span-3 min-[901px]:row-span-1";

const getProjectHref = (project: (typeof projects)[number]) => translatePath(`/project/${project.id}/`);
const getProjectKind = (project: (typeof projects)[number]) =>
    project.data.kind ?? (project.data.links.website ? "Side" : "Code");
const getProjectStack = (project: (typeof projects)[number]) => project.data.tag.slice(0, 5).map((t) => t.name).join(" · ");
const rotationData = projects.slice(1).map((p) => ({
    kind: getProjectKind(p),
    year: String(p.data.year),
    name: p.data.name,
    description: p.data.description,
    stack: getProjectStack(p),
    href: getProjectHref(p),
}));
---

<div
    class="flex h-dvh min-h-dvh w-full flex-col gap-2.5 overflow-hidden bg-portfolio-bg p-3.5 font-portfolio text-portfolio-ink antialiased [font-feature-settings:'ss01','cv11'] max-[900px]:h-auto max-[900px]:overflow-visible max-[560px]:p-2.5">
    <header
        class="flex flex-none items-baseline justify-between gap-4 px-1 text-sm tracking-[-0.01em] max-[900px]:items-start">
        <a class="whitespace-nowrap font-semibold" href={translatePath("/")} aria-label="Benjamin Fabri">
            Benjamin Fabri<span class="text-portfolio-blue">.</span>
        </a>
        <nav class="flex items-baseline gap-[22px] whitespace-nowrap max-[900px]:gap-3.5 max-[900px]:text-[13px]" aria-label="Navigation principale">
            <a class="text-portfolio-muted transition-colors hover:text-portfolio-ink" href={languageHref}>{copy.language}</a>
            <a class="text-portfolio-muted transition-colors hover:text-portfolio-ink max-[560px]:hidden" href="https://github.com/befabri/" target="_blank" rel="noopener">GitHub</a>
            <ToggleTheme />
            <a class="border-b-[1.5px] border-portfolio-blue pb-px text-portfolio-ink" href={`mailto:${email}`}><!--email_off-->{email}<!--/email_off--></a>
        </nav>
    </header>

    <main
        class="grid flex-1 auto-rows-[minmax(140px,auto)] grid-cols-1 gap-2.5 min-[901px]:min-h-0 min-[901px]:grid-cols-12 min-[901px]:grid-rows-6 min-[901px]:auto-rows-auto"
        aria-label="Portfolio">
        <section
            class:list={[
                cardClass,
                "justify-between px-10 pb-8 pt-9 min-[901px]:col-span-8 min-[901px]:row-span-3 max-[900px]:min-h-[360px] max-[900px]:px-7 max-[900px]:pb-7 max-[900px]:pt-[30px] max-[560px]:p-5",
            ]}>
            <div class="text-[15px] leading-[1.35] tracking-[-0.01em] text-portfolio-muted">
                <b class="font-medium text-portfolio-ink">{copy.roleLead}</b>
                {" "}{copy.role}
            </div>
            <h1 class="mt-1.5 text-[clamp(56px,8.4vw,144px)] font-semibold leading-[0.86] tracking-[-0.055em] max-[560px]:text-[clamp(58px,22vw,96px)]">
                Benjamin<br />
                <i class="not-italic font-normal tracking-[-0.06em]">Fabri</i><span
                    class="inline-block cursor-pointer select-none text-portfolio-blue transition-transform duration-150 ease-out hover:scale-110 active:scale-95"
                    data-rotate-trigger
                    role="button"
                    tabindex="0"
                    aria-label={isFr ? "Faire tourner les projets" : "Rotate projects"}>.</span>
            </h1>
            <div class="flex items-end justify-between gap-6 text-sm text-portfolio-muted max-[560px]:flex-col max-[560px]:items-start">
                <span class="flex items-center gap-2 before:inline-block before:size-[7px] before:shrink-0 before:rounded-full before:bg-portfolio-blue before:content-['']">
                    {copy.locationCity} · {copy.workLabel}{" "}
                    <a class="border-b-[1.5px] border-portfolio-blue pb-px text-portfolio-ink hover:text-portfolio-blue" href="https://digitalmaster.be/" target="_blank" rel="noopener">Digital Master</a>
                </span>
                <span>{copy.meta}</span>
            </div>
        </section>

        <section
            class:list={[
                cardClass,
                "justify-between px-[26px] py-6 min-[901px]:col-span-4 min-[901px]:row-span-3 max-[560px]:p-5",
            ]}>
            <div>
                <div class="text-[13px] tracking-[-0.01em] text-portfolio-muted">{copy.selected}</div>
                <ul class="mt-3 flex list-none flex-col">
                    {
                        projects.map((project) => (
                            <li class="last:border-b last:border-portfolio-ink">
                                <a
                                    class="group flex items-baseline justify-between gap-3.5 border-t border-portfolio-ink py-2.5 text-[clamp(15px,1.15vw,19px)] font-medium tracking-[-0.02em] hover:text-portfolio-blue"
                                    href={getProjectHref(project)}>
                                    <span>{project.data.name}</span>
                                    <span class="inline-flex min-w-0 items-baseline">
                                        <span class="text-xs font-normal text-portfolio-muted tabular-nums group-hover:text-portfolio-blue">
                                            {project.data.year}
                                        </span>
                                        <span class="ml-2.5 inline-block text-portfolio-muted transition duration-300 ease-out group-hover:translate-x-2 group-hover:text-portfolio-blue">
                                            →
                                        </span>
                                    </span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div class="mt-3 text-xs leading-[1.35] text-portfolio-muted">{copy.count}</div>
        </section>

        {
            featured && (
                <section class:list={[cardClass, "p-0 min-[901px]:col-span-6 min-[901px]:row-span-3"]}>
                    <a
                        class="group flex flex-1 flex-col justify-between bg-portfolio-blue px-9 py-[30px] text-white max-[900px]:min-h-[280px]"
                        href={getProjectHref(featured)}>
                        <div class="flex items-baseline justify-between text-[13px] tracking-[-0.01em] opacity-85">
                            <span>{copy.featured}</span>
                            <span class="tabular-nums">{featured.data.year}</span>
                        </div>
                        <div>
                            <h2 class="mt-2.5 text-balance text-[clamp(36px,4.2vw,68px)] font-semibold leading-[0.95] tracking-[-0.04em]">
                                {featured.data.name}
                            </h2>
                            <p class="mt-4 max-w-[54ch] text-pretty text-[15px] leading-[1.4] opacity-90">
                                {featured.data.description}
                            </p>
                        </div>
                        <div class="flex items-end justify-between gap-[18px] max-[560px]:flex-col max-[560px]:items-start">
                            <span class="min-w-0 truncate text-[13px] tracking-[-0.01em] opacity-85">
                                {getProjectStack(featured)}
                            </span>
                            <span class="inline-flex shrink-0 items-center gap-1.5 whitespace-nowrap border-b-[1.5px] border-current pb-px text-[13px] transition-transform duration-300 ease-out group-hover:translate-x-1">
                                {copy.openCase}
                                <span class="relative inline-block size-3.5 overflow-hidden">
                                    <ArrowRight class="size-3.5 transition-transform duration-300 ease-out group-hover:translate-x-full" />
                                    <ArrowRight class="absolute inset-0 size-3.5 -translate-x-full transition-transform duration-300 ease-out group-hover:translate-x-0" />
                                </span>
                            </span>
                        </div>
                    </a>
                </section>
            )
        }

        {
            projectCards.map((project, index) => (
                <a class:list={[cardClass, linkCardClass, projectCardCorners[index], projectCardLayouts[index]]} data-reveal-side={projectCardSides[index]} data-rotating-card={index} href={getProjectHref(project)}>
                    <div data-rot-content class="flex flex-1 flex-col justify-between will-change-transform">
                        <div class="top flex items-baseline justify-between gap-2 whitespace-nowrap text-xs opacity-60">
                            <span class="truncate" data-rot-kind>{getProjectKind(project)}</span>
                            <span class="truncate tabular-nums" data-rot-year>{project.data.year}</span>
                        </div>
                        <div>
                            <h3 class="mt-2 text-[clamp(22px,1.8vw,30px)] font-semibold leading-none tracking-[-0.03em]" data-rot-name>
                                {project.data.name}
                            </h3>
                            <p class="sub mt-2 text-pretty text-[13px] leading-[1.35] opacity-60" data-rot-desc>
                                {project.data.description}
                            </p>
                        </div>
                        <div class="stack mt-3 text-xs tracking-[-0.005em] opacity-60" data-rot-stack>
                            {getProjectStack(project)}
                        </div>
                    </div>
                </a>
            ))
        }

        <a
            class:list={[
                "group relative flex min-h-0 min-w-0 flex-col justify-between overflow-hidden rounded-portfolio border border-portfolio-ink bg-portfolio-ink px-6 py-[22px] text-portfolio-bg before:pointer-events-none before:absolute before:inset-0 before:bg-portfolio-blue before:opacity-0 before:[clip-path:circle(0%_at_var(--reveal-x)_var(--reveal-y))] before:[transition:opacity_250ms_ease-out,clip-path_0ms_250ms] hover:before:opacity-100 hover:before:[clip-path:circle(150%_at_var(--reveal-x)_var(--reveal-y))] hover:before:[transition:opacity_0ms,clip-path_800ms_ease-out] [&>*]:relative max-[560px]:p-5",
                revealRight,
                contactLayout,
            ]}
            data-reveal-side="right"
            href={`mailto:${email}`}
            aria-label={copy.contact}>
            <div class="flex items-center gap-2 text-[11px] opacity-75">
                {copy.contact} · {copy.contactStatus}
            </div>
            <div class="mt-2 flex items-baseline justify-between gap-2">
                <span class="truncate text-[clamp(14px,1.3vw,18px)] font-semibold tracking-[-0.02em]">
                    <!--email_off-->{email}<!--/email_off-->
                </span>
                <ArrowUpRight class="size-4 shrink-0 transition-transform duration-300 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
            </div>
        </a>
    </main>
</div>

<script define:vars={{ rotationData, projectCardLayouts }}>
    (() => {
        const setupProjectRotation = () => {
            window.__homeBentoRotationCleanup?.();
            window.__homeBentoRotationCleanup = undefined;

            const cards = Array.from(document.querySelectorAll("[data-rotating-card]"));
            const trigger = document.querySelector("[data-rotate-trigger]");
            if (!(cards.length === 3 && trigger && rotationData.length > cards.length)) return;

            let nextIndex = cards.length % rotationData.length;
            let isAnimating = false;

            const updateData = (card, data) => {
                card.setAttribute("href", data.href);
                const set = (sel, val) => {
                    const el = card.querySelector(sel);
                    if (el) el.textContent = val;
                };
                set("[data-rot-kind]", data.kind);
                set("[data-rot-year]", data.year);
                set("[data-rot-name]", data.name);
                set("[data-rot-desc]", data.description);
                set("[data-rot-stack]", data.stack);
            };

            const readData = (card) => ({
                href: card.getAttribute("href") || "",
                kind: card.querySelector("[data-rot-kind]")?.textContent || "",
                year: card.querySelector("[data-rot-year]")?.textContent || "",
                name: card.querySelector("[data-rot-name]")?.textContent || "",
                description: card.querySelector("[data-rot-desc]")?.textContent || "",
                stack: card.querySelector("[data-rot-stack]")?.textContent || "",
            });

            const setWrapper = (card, opacity, transform) => {
                const w = card.querySelector("[data-rot-content]");
                if (w) {
                    w.style.opacity = String(opacity);
                    w.style.transform = transform;
                }
            };

            const cloneAt = (card) => {
                const rect = card.getBoundingClientRect();
                const clone = card.cloneNode(true);
                clone.removeAttribute("data-rotating-card");
                clone.removeAttribute("data-reveal-side");
                clone.style.position = "fixed";
                clone.style.margin = "0";
                clone.style.left = `${rect.left}px`;
                clone.style.top = `${rect.top}px`;
                clone.style.width = `${rect.width}px`;
                clone.style.height = `${rect.height}px`;
                clone.style.zIndex = "100";
                clone.style.transformOrigin = "top left";
                clone.style.pointerEvents = "none";
                const cw = clone.querySelector("[data-rot-content]");
                if (cw) {
                    cw.style.opacity = "1";
                    cw.style.transform = "translate(0, 0)";
                }
                return { clone, rect };
            };

            const waitForAnimation = (animation) =>
                animation.finished.catch((error) => {
                    if (error?.name === "AbortError") return;
                    throw error;
                });

            const rotate = async () => {
                if (isAnimating) return;
                isAnimating = true;
                let c0 = null;
                let c1 = null;
                let c2 = null;
                let animNew = null;

                try {
                    const slot0Data = readData(cards[0]);
                    const slot2Data = readData(cards[2]);
                    const newData = rotationData[nextIndex];

                    // Snapshot current state into clones (before any data updates)
                    c0 = cloneAt(cards[0]);
                    c1 = cloneAt(cards[1]);
                    c2 = cloneAt(cards[2]);

                    // Strip slot 2's layout overrides from the clone so it inherits the default
                    // (slot 0-like) layout while it flies up — no content shift on landing.
                    projectCardLayouts[2]
                        .split(/\s+/)
                        .filter(Boolean)
                        .forEach((cls) => {
                            c2.clone.classList.remove(cls);
                        });

                    // Hide all source wrappers — clones take over visually
                    setWrapper(cards[0], 0, "translate(0, 0)");
                    setWrapper(cards[1], 0, "translate(0, 0)");
                    setWrapper(cards[2], 0, "translate(0, 0)");

                    cards[0].parentElement.appendChild(c0.clone);
                    cards[0].parentElement.appendChild(c1.clone);
                    cards[0].parentElement.appendChild(c2.clone);

                    // Update underlying cards immediately — they'll be revealed when clones land
                    updateData(cards[0], slot2Data);
                    updateData(cards[1], slot0Data);
                    updateData(cards[2], newData);

                    const duration = 600;
                    const easing = "cubic-bezier(0.4, 0, 0.2, 1)";

                    // Slot 0 → slot 1: morph position + size (no scale stretch on text)
                    const anim0to1 = c0.clone.animate(
                        [
                            { left: `${c0.rect.left}px`, top: `${c0.rect.top}px`, width: `${c0.rect.width}px`, height: `${c0.rect.height}px` },
                            { left: `${c1.rect.left}px`, top: `${c1.rect.top}px`, width: `${c1.rect.width}px`, height: `${c1.rect.height}px` },
                        ],
                        { duration, easing, fill: "forwards" },
                    );
                    // Slot 1's old content disappears downward — opacity drops fast, motion keeps full duration
                    const anim1down = c1.clone.animate(
                        [
                            { transform: "translate(0, 0)", opacity: 1, offset: 0 },
                            { opacity: 0, offset: 0.12 },
                            { transform: "translate(0, 100%)", opacity: 0, offset: 1 },
                        ],
                        { duration, easing, fill: "forwards" },
                    );
                    // Slot 2 → slot 0: morph position + size (no scale stretch on text)
                    const anim2to0 = c2.clone.animate(
                        [
                            { left: `${c2.rect.left}px`, top: `${c2.rect.top}px`, width: `${c2.rect.width}px`, height: `${c2.rect.height}px` },
                            { left: `${c0.rect.left}px`, top: `${c0.rect.top}px`, width: `${c0.rect.width}px`, height: `${c0.rect.height}px` },
                        ],
                        { duration, easing, fill: "forwards" },
                    );
                    // New content drops into slot 2 from below (overlaps the cycle)
                    const wrapper2 = cards[2].querySelector("[data-rot-content]");
                    animNew = wrapper2
                        ? wrapper2.animate(
                              [
                                  { transform: "translate(0, 100%)", opacity: 0 },
                                  { transform: "translate(0, 0)", opacity: 1 },
                              ],
                              {
                                  duration: duration * 0.7,
                                  delay: duration * 0.3,
                                  easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                                  fill: "forwards",
                              },
                          )
                        : null;

                    await Promise.all(
                        [anim0to1, anim1down, anim2to0, animNew]
                            .filter(Boolean)
                            .map(waitForAnimation),
                    );

                    nextIndex = (nextIndex + 1) % rotationData.length;
                } finally {
                    setWrapper(cards[0], 1, "translate(0, 0)");
                    setWrapper(cards[1], 1, "translate(0, 0)");
                    setWrapper(cards[2], 1, "translate(0, 0)");

                    // Cancel persistent animation effects so the next rotation's inline opacity:0 takes over
                    if (animNew) animNew.cancel();

                    c0?.clone.remove();
                    c1?.clone.remove();
                    c2?.clone.remove();

                    isAnimating = false;
                }
            };

            const handleKeydown = (event) => {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    rotate();
                }
            };

            trigger.addEventListener("click", rotate);
            trigger.addEventListener("keydown", handleKeydown);

            window.__homeBentoRotationCleanup = () => {
                trigger.removeEventListener("click", rotate);
                trigger.removeEventListener("keydown", handleKeydown);
            };
        };

        if (window.__homeBentoRotationSetup) {
            document.removeEventListener("astro:page-load", window.__homeBentoRotationSetup);
        }

        window.__homeBentoRotationSetup = setupProjectRotation;
        setupProjectRotation();
        document.addEventListener("astro:page-load", setupProjectRotation);
    })();
</script>
